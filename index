<script>
const K='mcas_v2';
let D={};
let navStack=[];
let currentScreen='s-welcome';
let currentSection='';
let demoMode=false;

function load(){
  try{const raw=localStorage.getItem(K);if(raw)D=JSON.parse(raw);}catch(e){D={};}
}
function save(){
  try{localStorage.setItem(K,JSON.stringify(D));}catch(e){}
}

function showScreen(id){
  if(currentScreen!==id)navStack.push(currentScreen);
  document.querySelectorAll('.screen').forEach(s=>{s.classList.remove('active');s.style.display='none';});
  const s=document.getElementById(id);
  s.classList.add('active');s.style.display='flex';
  currentScreen=id;
  const noTop=['s-welcome','s-home'];
  document.getElementById('top-bar').style.display=noTop.includes(id)?'none':'flex';
  const titles={'s-ob1':'Pre-flare signals','s-ob2':'Trigger map','s-ob3':'Medications','s-ob4':'Emergency info','s-ob5':'Setup complete','s-flare':'Flare response','s-section':'My protocol','s-provider':'Provider mode','s-log':'Flare log','s-log-add':'Log entry','s-settings':'Settings'};
  document.getElementById('top-title').textContent=titles[id]||'MCAS Flare Guide';
  if(id==='s-home')updateHome();
  if(id==='s-log')renderLog();
  if(id==='s-settings')updateSettings();
  window.scrollTo(0,0);
}
function goBack(){const prev=navStack.pop();if(prev&&prev!==currentScreen)showScreen(prev);else goHome();}
function goHome(){navStack=[];showScreen('s-home');}

function showWelcomeDemo(){
  demoMode=true;
  document.getElementById('demo-bar').style.display='flex';
  navStack=[];showScreen('s-welcome');
  if(D.context)highlightContext(D.context);
}
function exitDemo(){
  demoMode=false;
  document.getElementById('demo-bar').style.display='none';
  goHome();
}

function highlightContext(ctx){
  document.getElementById('ctx-adult').className='btn btn-full ctx-btn'+(ctx==='adult'?' selected':'');
  document.getElementById('ctx-care').className='btn btn-full ctx-btn'+(ctx==='caregiver'?' selected':'');
  document.getElementById('ctx-adult').style.cssText+=(ctx==='adult'?';padding:14px;flex-direction:column;gap:6px;border-radius:var(--border-radius-lg)':';padding:14px;flex-direction:column;gap:6px;border-radius:var(--border-radius-lg)');
}
function setContext(ctx){
  D.context=ctx;
  highlightContext(ctx);
  const isAdult=ctx!=='caregiver';
  const lm=(id,t)=>{const el=document.getElementById(id);if(el)el.textContent=t;};
  lm('ob1-title',isAdult?'Your pre-flare pattern':"Your child's pre-flare pattern");
  lm('ob1-sub',isAdult?'These are the signs your body gives before a full flare. Learning your personal pattern is one of the most powerful things you can do.':"These are the signs your child shows before a full flare. Learning their pattern helps you catch it early.");
  lm('lb-earliest',isAdult?'My earliest warning signs are usually':"My child's earliest warning signs are usually");
  lm('lb-canary',isAdult?"My single most reliable first signal":"Their single most reliable first signal");
  lm('lb-context',isAdult?'I notice these signals most often when':'These signals tend to appear');
  lm('lb-firstdo',isAdult?'When I notice these signals, I first':'When I see these signals, I first');
  lm('lb-name',isAdult?'My name':"Patient's name");
  lm('lb-dob',isAdult?'Date of birth':"Patient's date of birth");
}
function startOnboarding(){showScreen('s-ob1');loadOb1();}

function v(id){const el=document.getElementById(id);return el?el.value.trim():'';}
function sv(id,val){const el=document.getElementById(id);if(el)el.value=val||'';}

function saveOb1(){D.signals={earliest:v('f-earliest'),canary:v('f-canary'),context:v('f-context'),firstdo:v('f-firstdo')};save();showScreen('s-ob2');loadOb2();}
function loadOb1(){const s=D.signals||{};sv('f-earliest',s.earliest);sv('f-canary',s.canary);sv('f-context',s.context);sv('f-firstdo',s.firstdo);if(D.context)setContext(D.context);}
function saveOb2(){D.triggers={food_c:v('f-food-c'),food_s:v('f-food-s'),chem:v('f-chem'),phys:v('f-phys'),bio:v('f-bio'),stress:v('f-stress'),stack:v('f-stack')};save();showScreen('s-ob3');loadOb3();}
function loadOb2(){const t=D.triggers||{};sv('f-food-c',t.food_c);sv('f-food-s',t.food_s);sv('f-chem',t.chem);sv('f-phys',t.phys);sv('f-bio',t.bio);sv('f-stress',t.stress);sv('f-stack',t.stack);}
function saveOb3(){D.meds={t1signs:v('f-t1-signs'),t1m1:v('f-t1-m1'),t1m2:v('f-t1-m2'),t1other:v('f-t1-other'),t2signs:v('f-t2-signs'),t2m1:v('f-t2-m1'),t2m2:v('f-t2-m2'),t2esc:v('f-t2-esc')};save();showScreen('s-ob4');loadOb4();}
function loadOb3(){const m=D.meds||{};sv('f-t1-signs',m.t1signs);sv('f-t1-m1',m.t1m1);sv('f-t1-m2',m.t1m2);sv('f-t1-other',m.t1other);sv('f-t2-signs',m.t2signs);sv('f-t2-m1',m.t2m1);sv('f-t2-m2',m.t2m2);sv('f-t2-esc',m.t2esc);}
function saveOb4(){D.emergency={epi_device:v('f-epi-device'),epi_loc:v('f-epi-loc'),epi_exp:v('f-epi-exp'),epi_loc2:v('f-epi-loc2'),ec1name:v('f-ec1-name'),ec1phone:v('f-ec1-phone'),ec2name:v('f-ec2-name'),ec2phone:v('f-ec2-phone'),er:v('f-er'),er_notes:v('f-er-notes'),name:v('f-name'),dob:v('f-dob')};save();showScreen('s-ob5');}
function loadOb4(){const e=D.emergency||{};sv('f-epi-device',e.epi_device);sv('f-epi-loc',e.epi_loc);sv('f-epi-exp',e.epi_exp);sv('f-epi-loc2',e.epi_loc2);sv('f-ec1-name',e.ec1name);sv('f-ec1-phone',e.ec1phone);sv('f-ec2-name',e.ec2name);sv('f-ec2-phone',e.ec2phone);sv('f-er',e.er);sv('f-er-notes',e.er_notes);sv('f-name',e.name);sv('f-dob',e.dob);}
function loadProvider(){const p=D.provider||{};sv('pf-t1-m1',p.t1m1||D.meds?.t1m1);sv('pf-t1-m2',p.t1m2||D.meds?.t1m2);sv('pf-t2-m1',p.t2m1||D.meds?.t2m1);sv('pf-t2-m2',p.t2m2||D.meds?.t2m2);sv('pf-t1-thresh',p.thresh);sv('pf-epi',p.epi||D.emergency?.epi_device);sv('pf-notes',p.notes);sv('pf-provider',p.provider_name);}
function saveProvider(){D.provider={t1m1:v('pf-t1-m1'),t1m2:v('pf-t1-m2'),t2m1:v('pf-t2-m1'),t2m2:v('pf-t2-m2'),thresh:v('pf-t1-thresh'),epi:v('pf-epi'),notes:v('pf-notes'),provider_name:v('pf-provider'),completed:true};save();goHome();}

function completion(){let f=0,t=4;if(D.signals?.earliest||D.signals?.canary)f++;if(D.triggers?.food_c||D.triggers?.chem)f++;if(D.meds?.t1signs||D.meds?.t1m1)f++;if(D.emergency?.ec1name||D.emergency?.er)f++;return Math.round((f/t)*100);}
function chip(has){return has?'complete-chip chip-done':'complete-chip chip-todo';}
function chipTxt(has){return has?'✓ Done':'Add info';}

function updateHome(){
  const isAdult=(D.context||'adult')!=='caregiver';
  document.getElementById('home-greeting').textContent=isAdult?'Your personalized flare guide':"Your child's personalized flare guide";
  const nm=D.emergency?.name;
  document.getElementById('home-name').textContent=nm?nm+"'s guide":'My MCAS guide';
  document.getElementById('sc-pct').textContent=completion()+'%';
  document.getElementById('sc-logcount').textContent=(D.logs||[]).length;
  document.getElementById('provider-banner').style.display=D.provider?.completed?'none':'';
  const s=D.signals,t=D.triggers,e=D.emergency;
  const cs=document.getElementById('chip-signals');cs.className=chip(s?.earliest||s?.canary);cs.textContent=chipTxt(s?.earliest||s?.canary);
  const ct=document.getElementById('chip-triggers');ct.className=chip(t?.food_c||t?.chem);ct.textContent=chipTxt(t?.food_c||t?.chem);
  const ce=document.getElementById('chip-emer');ce.className=chip(e?.ec1name||e?.er);ce.textContent=chipTxt(e?.ec1name||e?.er);
}
function updateSettings(){
  const isAdult=(D.context||'adult')!=='caregiver';
  document.getElementById('set-adult').style.borderColor=isAdult?'#1A7A8A':'';
  document.getElementById('set-care').style.borderColor=!isAdult?'#1A7A8A':'';
}

function setFlareTab(tier){
  ['t1','t2','t3','t4'].forEach(t=>{const b=document.getElementById('tb-'+t);b.className='tier-btn';if(t===tier)b.classList.add('active-'+t);});
  renderTier(tier);
}
function row(dot,html){return`<div class="check-item"><div class="check-dot dot-${dot}"></div><span>${html}</span></div>`;}
function mrow(label,val,fallback){return val?`<div class="mline"><span class="mline-label">${label}: </span><strong>${val}</strong></div>`:`<div class="mline"><span class="mline-label">${label}: </span><em style="color:var(--color-text-secondary)">${fallback}</em></div>`;}

function renderTier(tier){
  const m=D.meds||{},p=D.provider||{},e=D.emergency||{};
  const isAdult=(D.context||'adult')!=='caregiver';
  const your=isAdult?'your':"your child's";
  const they=isAdult?'you':"your child";
  let html='';
  if(tier==='t1'){
    html=`<div class="tier-header t1-header"><h2>Tier 1 — Mild flare</h2><p>Respond early. The cost of acting on nothing is low. The cost of waiting is high.</p></div>`;
    html+=`<h3 style="margin-bottom:8px">${isAdult?'Your':'Your child\'s'} Tier 1 signals</h3>`;
    if(m.t1signs)html+=`<div class="card" style="margin-bottom:1rem"><p style="font-size:14px;color:var(--color-text-primary)">${m.t1signs}</p></div>`;
    else{html+=`<div class="card" style="margin-bottom:1rem">`;['Mild itching, flushing, or hives in one area','Early nausea or stomach change','Brain fog arriving, mild headache','Pre-flare signals present'].forEach(x=>html+=row('green',x));html+='</div>';}
    html+=`<h3 style="margin-bottom:8px">Action</h3><div class="card" style="margin-bottom:1rem">`;
    const t1m1=p.t1m1||m.t1m1,t1m2=p.t1m2||m.t1m2;
    if(t1m1)html+=row('green',`Take ${t1m1}`);else html+=row('green','Take scheduled H1 antihistamine if not yet taken');
    if(t1m2)html+=row('green',`Take ${t1m2}`);else html+=row('green','Take H2 antihistamine (e.g. famotidine)');
    if(m.t1other)html+=row('green',m.t1other);
    html+=row('green','Remove yourself from any identifiable trigger');
    html+=row('green','Cool, calm environment — rest, hydrate, low stimulation');
    html+=row('green','Note time and possible triggers');
    html+='</div>';
    const thresh=p.thresh||'30–60 minutes';
    html+=`<button class="escalate-btn esc-t2" onclick="setFlareTab('t2')"><span>Not improving after ${thresh}</span><i class="ti ti-arrow-right" aria-hidden="true"></i></button>`;
  } else if(tier==='t2'){
    html=`<div class="tier-header t2-header"><h2>Tier 2 — Moderate flare</h2><p>Escalate. Have someone with ${they} if possible.</p></div>`;
    html+=`<h3 style="margin-bottom:8px">Tier 2 signals</h3>`;
    if(m.t2signs)html+=`<div class="card" style="margin-bottom:1rem"><p style="font-size:14px;color:var(--color-text-primary)">${m.t2signs}</p></div>`;
    else{html+=`<div class="card" style="margin-bottom:1rem">`;['Hives spreading; angioedema (not throat)','Significant cramping, vomiting','Moderate wheezing — still speaking in full sentences','Heart racing; lightheaded on standing','Significant brain fog or confusion'].forEach(x=>html+=row('amber',x));html+='</div>';}
    html+=`<h3 style="margin-bottom:8px">Action</h3><div class="card" style="margin-bottom:1rem">`;
    const t2m1=p.t2m1||m.t2m1,t2m2=p.t2m2||m.t2m2;
    if(t2m1)html+=row('amber',`Add rescue dose: ${t2m1}`);else html+=row('amber','Add rescue H1 antihistamine dose now');
    if(t2m2)html+=row('amber',`Steroid: ${t2m2}`);else html+=row('amber','Consider oral steroid if prescribed for moderate rescue');
    html+=row('amber',`Lie down, elevate ${your} legs slightly`);
    html+=row('amber','Do not eat or add new substances until clearly improving');
    html+=row('amber','Have someone with you if possible — let someone know');
    html+='</div>';
    const esc=m.t2esc||'throat tightness, tongue swelling, or blood pressure drop';
    html+=`<div class="warn-box"><strong>Watch for:</strong> ${esc} → move to Tier 3 immediately</div>`;
    html+=`<button class="escalate-btn esc-t3" onclick="setFlareTab('t3')"><span>Symptoms escalating — move to Tier 3</span><i class="ti ti-arrow-right" aria-hidden="true"></i></button>`;
  } else if(tier==='t3'){
    html=`<div class="tier-header t3-header"><h2>Tier 3 — Severe</h2><p>This is serious. Act now. Call someone.</p></div>`;
    html+=`<h3 style="margin-bottom:8px">Tier 3 criteria</h3><div class="card" style="margin-bottom:1rem">`;
    ['Cannot complete a sentence without stopping','SpO₂ ≤ 93% / significant breathing difficulty','Heart rate > 120 at rest','Blood pressure dropping — near-faint, severe dizziness','Throat tightness, stridor, tongue or throat swelling','Rapid escalation not slowing'].forEach(x=>html+=row('coral',x));
    html+='</div>';
    html+=`<h3 style="margin-bottom:8px">Action — now</h3><div class="card" style="margin-bottom:1rem">`;
    const epi=p.epi||e.epi_device;
    if(epi)html+=row('coral',`<strong>Use epinephrine NOW: ${epi}</strong> — outer thigh, through clothing if needed, do not wait`);
    else html+=row('coral','<strong>Use epinephrine auto-injector NOW</strong> — outer thigh, through clothing if needed');
    html+=row('coral','<strong>Call 911</strong> immediately');
    html+=row('coral','Lie flat — unless breathing is easier upright');
    html+=row('coral','Tell EMS: MCAS reaction — needs epinephrine, IV fluids, steroids if needed');
    html+=row('coral','Go to ER regardless of whether symptoms improve');
    html+='</div>';
    if(e.epi_loc)html+=`<div class="info-box"><i class="ti ti-map-pin" aria-hidden="true"></i> <strong>Epinephrine is at: ${e.epi_loc}</strong></div>`;
    html+=`<button class="escalate-btn esc-t4" onclick="setFlareTab('t4')"><span>Airway closing, collapse, or loss of consciousness</span><i class="ti ti-arrow-right" aria-hidden="true"></i></button>`;
  } else if(tier==='t4'){
    html=`<div class="tier-header t4-header"><h2>Tier 4 — Anaphylaxis</h2><p>No decisions. Act. This is the algorithm.</p></div>`;
    html+=`<div class="card card-red" style="margin-bottom:1rem">`;
    ['Throat closing or severe difficulty breathing','Tongue or throat swelling','Collapse or loss of consciousness','Any of the above — this is Tier 4'].forEach(x=>html+=row('red',x));
    html+='</div>';
    html+=`<h3 style="margin-bottom:8px">Algorithm — in order</h3><div class="card" style="margin-bottom:1rem">`;
    const epi2=p.epi||e.epi_device||'0.3mg adult / 0.15mg under 30kg / 0.1mg under 15kg';
    html+=row('red',`<strong>1. Epinephrine now:</strong> ${epi2} — outer thigh, through clothing`);
    html+=row('red','<strong>2. Call 911.</strong> Say: "I am having anaphylaxis"');
    html+=row('red','3. Lie flat, elevate legs (unless breathing easier upright)');
    html+=row('red','4. Second dose in 5–15 min if not improving and second device available');
    html+=row('red','5. Go to ER — even if completely better. Biphasic reaction can occur 1–72 hours later');
    html+='</div>';
    if(e.ec1name||e.ec2name||e.er){
      html+=`<h3 style="margin-bottom:8px">Emergency contacts</h3><div class="card" style="margin-bottom:1rem">`;
      if(e.ec1name)html+=`<div class="emer-item"><i class="ti ti-phone" style="font-size:18px;color:var(--color-text-secondary)" aria-hidden="true"></i><span class="emer-label">${e.ec1name}</span><strong>${e.ec1phone||'—'}</strong></div>`;
      if(e.ec2name)html+=`<div class="emer-item"><i class="ti ti-phone" style="font-size:18px;color:var(--color-text-secondary)" aria-hidden="true"></i><span class="emer-label">${e.ec2name}</span><strong>${e.ec2phone||'—'}</strong></div>`;
      if(e.er)html+=`<div class="emer-item"><i class="ti ti-building-hospital" style="font-size:18px;color:var(--color-text-secondary)" aria-hidden="true"></i><span class="emer-label">Preferred ER</span><span style="font-size:13px">${e.er}</span></div>`;
      html+='</div>';
    }
    if(e.epi_loc2)html+=`<div class="info-box"><strong>Second device: </strong>${e.epi_loc2}</div>`;
    html+=`<div class="warn-box" style="font-size:13px"><strong>Always go to the ER after using epinephrine</strong> — even when symptoms resolve. Biphasic anaphylaxis can occur hours later. Minimum 4–6 hours observation.</div>`;
  }
  document.getElementById('flare-content').innerHTML=html;
}

function showSection(which){
  currentSection=which;
  const m=D.meds||{},t=D.triggers||{},s=D.signals||{},e=D.emergency||{};
  let html='';
  if(which==='signals'){
    html=`<h2 style="margin-bottom:1rem">Pre-flare signals</h2>`;
    html+=mrow('Earliest warning signs',s.earliest,'Not yet filled in');
    html+=mrow('Canary signal',s.canary,'Not yet filled in');
    html+=mrow('When they appear',s.context,'Not yet filled in');
    html+=mrow('First action',s.firstdo,'Not yet filled in');
  } else if(which==='triggers'){
    html=`<h2 style="margin-bottom:1rem">Trigger map</h2>`;
    html+=`<h3 style="margin:1rem 0 6px">Food / ingested</h3>`;
    html+=mrow('Confirmed',t.food_c,'Not yet filled in');
    html+=mrow('Suspected',t.food_s,'Not yet filled in');
    html+=`<h3 style="margin:1rem 0 6px">Chemical / environmental</h3>`;
    html+=mrow('Triggers',t.chem,'Not yet filled in');
    html+=`<h3 style="margin:1rem 0 6px">Other triggers</h3>`;
    html+=mrow('Physical',t.phys,'Not yet filled in');
    html+=mrow('Biological / hormonal',t.bio,'Not yet filled in');
    html+=mrow('Stress / autonomic',t.stress,'Not yet filled in');
    html+=`<h3 style="margin:1rem 0 6px">Stacking combination</h3>`;
    html+=mrow('My highest-load pattern',t.stack,'Not yet filled in');
  } else if(which==='emergency'){
    html=`<h2 style="margin-bottom:1rem">Emergency information</h2>`;
    html+=mrow('Patient',e.name,'Not yet filled in');
    html+=mrow('Date of birth',e.dob,'—');
    html+=`<h3 style="margin:1rem 0 6px">Epinephrine</h3>`;
    html+=mrow('Device',e.epi_device,'Not yet filled in');
    html+=mrow('Location',e.epi_loc,'Not yet filled in');
    html+=mrow('Expiration',e.epi_exp,'Not yet filled in');
    html+=mrow('Second device',e.epi_loc2,'Not yet filled in');
    html+=`<h3 style="margin:1rem 0 6px">Emergency contacts</h3>`;
    html+=mrow(e.ec1name||'Contact 1',e.ec1phone,'Not yet filled in');
    html+=mrow(e.ec2name||'Contact 2',e.ec2phone,'Not yet filled in');
    html+=mrow('Preferred ER',e.er,'Not yet filled in');
    html+=mrow('Notes for ER',e.er_notes,'None added');
  }
  document.getElementById('section-content').innerHTML=html;
  showScreen('s-section');
}
function editSection(){
  const map={signals:'s-ob1',triggers:'s-ob2',emergency:'s-ob4'};
  const loaders={signals:loadOb1,triggers:loadOb2,emergency:loadOb4};
  if(map[currentSection]){showScreen(map[currentSection]);if(loaders[currentSection])loaders[currentSection]();}
}

function prefillLogDate(){document.getElementById('la-date').value=new Date().toISOString().split('T')[0];}
function renderLog(){
  const logs=D.logs||[];
  if(!logs.length){document.getElementById('log-list').innerHTML=`<p style="color:var(--color-text-secondary);font-size:14px;text-align:center;padding:2rem 0">No entries yet. Log your first flare to start tracking patterns.</p>`;return;}
  const sorted=[...logs].sort((a,b)=>new Date(b.date)-new Date(a.date));
  const tc=['','green','amber','coral','red'];
  let html='';
  sorted.forEach(l=>{
    const dots=Array.from({length:10},(_,i)=>`<div class="sev-dot${i<l.sev?' filled':''}"></div>`).join('');
    html+=`<div class="log-entry"><div style="display:flex;justify-content:space-between;align-items:center"><strong style="font-size:14px">${l.date}</strong><span class="pill pill-${tc[l.tier]||'teal'}">Tier ${l.tier}</span></div><div class="sev-bar" style="margin:4px 0">${dots}</div>`;
    if(l.syms)html+=`<div style="font-size:13px;color:var(--color-text-secondary);margin-top:4px">${l.syms}</div>`;
    if(l.triggers)html+=`<div style="font-size:12px;color:var(--color-text-secondary);margin-top:2px">Possible triggers: ${l.triggers}</div>`;
    html+='</div>';
  });
  document.getElementById('log-list').innerHTML=html;
}
function saveLogEntry(){
  if(!D.logs)D.logs=[];
  D.logs.push({date:v('la-date')||new Date().toISOString().split('T')[0],sev:parseInt(document.getElementById('la-sev').value)||5,tier:parseInt(document.getElementById('la-tier').value)||1,syms:v('la-syms'),triggers:v('la-triggers'),meds:v('la-meds'),notes:v('la-notes')});
  save();showScreen('s-log');
}
function resetAll(){D={};save();navStack=[];demoMode=false;document.getElementById('demo-bar').style.display='none';showScreen('s-welcome');}

function init(){
  load();
  if(D.emergency?.name||D.signals?.earliest){goHome();}
  else{showScreen('s-welcome');}
  if(D.context)setContext(D.context);
  updateSettings();
}
init();
</script>
