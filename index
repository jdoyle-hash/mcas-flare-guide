<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="MCAS Flare Guide">
  <meta name="theme-color" content="#1A7A8A">
  <meta name="description" content="Personalized MCAS flare recognition and response guide">
  <title>MCAS Flare Guide</title>
  <link rel="manifest" href="manifest.json">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  <style>
    :root {
      --color-background-primary: #ffffff;
      --color-background-secondary: #f3f4f6;
      --color-background-tertiary: #f9fafb;
      --color-text-primary: #111827;
      --color-text-secondary: #6b7280;
      --color-border-tertiary: rgba(0,0,0,0.08);
      --color-border-secondary: rgba(0,0,0,0.15);
      --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      --border-radius-md: 8px;
      --border-radius-lg: 12px;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --color-background-primary: #1c1c1e;
        --color-background-secondary: #2c2c2e;
        --color-background-tertiary: #242426;
        --color-text-primary: #f2f2f7;
        --color-text-secondary: #aeaeb2;
        --color-border-tertiary: rgba(255,255,255,0.08);
        --color-border-secondary: rgba(255,255,255,0.15);
      }
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;overflow:hidden}
    body{font-family:var(--font-sans);background:var(--color-background-tertiary);color:var(--color-text-primary);display:flex;justify-content:center}
    .app{width:100%;max-width:480px;height:100%;display:flex;flex-direction:column;background:var(--color-background-primary);position:relative;overflow:hidden}
    .screen{display:none;flex-direction:column;flex:1;overflow:hidden}
    .screen.active{display:flex}
    .screen-scroll{flex:1;overflow-y:auto;padding:1.25rem;-webkit-overflow-scrolling:touch}
    .top-bar{display:flex;align-items:center;gap:10px;padding:0.75rem 1.25rem;border-bottom:0.5px solid var(--color-border-tertiary);flex-shrink:0}
    .top-bar h1{font-size:15px;font-weight:500;flex:1}
    .back-btn{background:none;border:none;cursor:pointer;color:var(--color-text-secondary);font-size:22px;padding:4px 6px;border-radius:6px;line-height:1;display:flex;align-items:center}
    .back-btn:hover{background:var(--color-background-secondary)}
    h2{font-size:18px;font-weight:500;margin-bottom:0.5rem}
    h3{font-size:15px;font-weight:500;margin-bottom:0.5rem}
    p{font-size:14px;color:var(--color-text-secondary);line-height:1.6}
    .card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1rem 1.25rem;margin-bottom:0.75rem}
    .card-amber{border-left:3px solid #854F0B;border-radius:0 var(--border-radius-lg) var(--border-radius-lg) 0}
    .card-red{border-left:3px solid #A32D2D;border-radius:0 var(--border-radius-lg) var(--border-radius-lg) 0}
    .btn{display:inline-flex;align-items:center;gap:6px;padding:10px 18px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-secondary);background:var(--color-background-primary);color:var(--color-text-primary);font-size:14px;cursor:pointer;font-family:var(--font-sans);-webkit-tap-highlight-color:transparent}
    .btn:hover{background:var(--color-background-secondary)}
    .btn:active{transform:scale(0.98)}
    .btn-primary{background:#1A7A8A;color:white;border-color:#1A7A8A}
    .btn-primary:hover{background:#155f6b}
    .btn-full{width:100%;justify-content:center}
    .btn-lg{padding:14px 20px;font-size:15px;border-radius:var(--border-radius-lg)}
    .btn-flare{background:#EAF3DE;color:#27500A;border:1.5px solid #639922;font-size:16px;font-weight:500;padding:16px 20px;border-radius:var(--border-radius-lg)}
    .btn-flare:hover{background:#C0DD97}
    .btn-ghost{background:none;border:none;color:var(--color-text-secondary);font-size:13px;cursor:pointer;font-family:var(--font-sans);padding:8px 0;display:inline-flex;align-items:center;gap:4px;-webkit-tap-highlight-color:transparent}
    .section-label{font-size:11px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin:1.25rem 0 0.5rem}
    .field{margin-bottom:1rem}
    .field label{display:block;font-size:13px;color:var(--color-text-secondary);margin-bottom:4px}
    .field input,.field textarea,.field select{width:100%;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);padding:8px 10px;font-size:14px;font-family:var(--font-sans);background:var(--color-background-primary);color:var(--color-text-primary);-webkit-appearance:none}
    .field textarea{min-height:72px;resize:vertical}
    .field input:focus,.field textarea:focus,.field select:focus{outline:none;border-color:#1A7A8A;box-shadow:0 0 0 2px rgba(26,122,138,0.15)}
    .progress-bar{height:3px;background:var(--color-border-tertiary);border-radius:2px;margin-bottom:1.5rem;flex-shrink:0}
    .progress-fill{height:100%;background:#1A7A8A;border-radius:2px;transition:width 0.3s}
    .tier-nav{display:flex;gap:6px;margin-bottom:1rem;flex-shrink:0;padding:0 1.25rem}
    .tier-btn{flex:1;padding:8px 4px;font-size:11px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);color:var(--color-text-secondary);cursor:pointer;font-family:var(--font-sans);text-align:center;line-height:1.3;-webkit-tap-highlight-color:transparent}
    .tier-btn.active-t1{background:#EAF3DE;color:#27500A;border-color:#639922;font-weight:500}
    .tier-btn.active-t2{background:#FAEEDA;color:#633806;border-color:#BA7517;font-weight:500}
    .tier-btn.active-t3{background:#FAECE7;color:#712B13;border-color:#D85A30;font-weight:500}
    .tier-btn.active-t4{background:#FCEBEB;color:#791F1F;border-color:#E24B4A;font-weight:500}
    .tier-header{padding:12px 16px;border-radius:var(--border-radius-md);margin-bottom:1rem}
    .t1-header{background:#EAF3DE;color:#27500A}
    .t2-header{background:#FAEEDA;color:#633806}
    .t3-header{background:#FAECE7;color:#712B13}
    .t4-header{background:#FCEBEB;color:#791F1F}
    .tier-header h2{color:inherit;font-size:16px;margin:0}
    .tier-header p{color:inherit;opacity:0.8;font-size:13px;margin-top:4px}
    .check-item{display:flex;align-items:flex-start;gap:10px;padding:8px 0;border-bottom:0.5px solid var(--color-border-tertiary);font-size:14px;line-height:1.5}
    .check-item:last-child{border-bottom:none}
    .check-dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0}
    .dot-green{background:#639922}
    .dot-amber{background:#BA7517}
    .dot-coral{background:#D85A30}
    .dot-red{background:#E24B4A}
    .escalate-btn{display:flex;align-items:center;justify-content:space-between;width:100%;padding:12px 16px;border-radius:var(--border-radius-md);border:0.5px solid;background:none;cursor:pointer;font-size:14px;font-family:var(--font-sans);margin-top:1rem;line-height:1.4;text-align:left;gap:8px;-webkit-tap-highlight-color:transparent}
    .esc-t2{border-color:#BA7517;color:#633806}
    .esc-t2:hover{background:#FAEEDA}
    .esc-t3{border-color:#D85A30;color:#712B13}
    .esc-t3:hover{background:#FAECE7}
    .esc-t4{border-color:#E24B4A;color:#791F1F}
    .esc-t4:hover{background:#FCEBEB}
    .emer-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:0.5px solid var(--color-border-tertiary);font-size:14px}
    .emer-item:last-child{border-bottom:none}
    .emer-label{color:var(--color-text-secondary);font-size:12px;min-width:90px}
    .complete-chip{font-size:11px;padding:2px 8px;border-radius:10px}
    .chip-done{background:#EAF3DE;color:#3B6D11}
    .chip-todo{background:var(--color-background-secondary);color:var(--color-text-secondary)}
    .home-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1rem}
    .stat-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:12px;text-align:center}
    .stat-num{font-size:22px;font-weight:500}
    .stat-lbl{font-size:12px;color:var(--color-text-secondary);margin-top:2px}
    .nav-tabs{display:flex;border-top:0.5px solid var(--color-border-tertiary);background:var(--color-background-primary);flex-shrink:0;padding-bottom:env(safe-area-inset-bottom)}
    .nav-tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 4px 8px;font-size:11px;color:var(--color-text-secondary);cursor:pointer;border:none;background:none;font-family:var(--font-sans);-webkit-tap-highlight-color:transparent}
    .nav-tab.active{color:#1A7A8A}
    .nav-tab i{font-size:20px}
    .lock-note{font-size:12px;color:#854F0B;background:#FAEEDA;border-radius:var(--border-radius-md);padding:8px 12px;margin-bottom:1rem;display:flex;align-items:center;gap:6px}
    .log-entry{padding:10px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
    .log-entry:last-child{border-bottom:none}
    .sev-bar{display:flex;gap:3px;margin-top:6px}
    .sev-dot{width:16px;height:6px;border-radius:3px;background:var(--color-border-tertiary)}
    .sev-dot.filled{background:#1A7A8A}
    .warn-box{background:#FCEBEB;border:0.5px solid #F7C1C1;border-radius:var(--border-radius-md);padding:10px 14px;margin-bottom:1rem;font-size:13px;color:#791F1F}
    .info-box{background:#E1F5EE;border:0.5px solid #9FE1CB;border-radius:var(--border-radius-md);padding:10px 14px;margin-bottom:1rem;font-size:13px;color:#085041}
    .divider{border:none;border-top:0.5px solid var(--color-border-tertiary);margin:1rem 0}
    .provider-field{border:0.5px dashed #BA7517;border-radius:var(--border-radius-md);padding:8px 12px;margin-bottom:8px}
    .provider-field label{font-size:12px;color:#854F0B;display:block;margin-bottom:2px}
    .provider-field input{border:none;background:none;padding:4px 0;font-size:14px;width:100%;color:var(--color-text-primary);font-family:var(--font-sans)}
    .provider-field input:focus{outline:none}
    .ctx-btn.selected{border-color:#1A7A8A;background:#E1F5EE;color:#085041}
    .pill{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:500}
    .pill-teal{background:#E1F5EE;color:#0F6E56}
    .pill-green{background:#EAF3DE;color:#3B6D11}
    .pill-amber{background:#FAEEDA;color:#854F0B}
    .pill-coral{background:#FAECE7;color:#993C1D}
    .pill-red{background:#FCEBEB;color:#A32D2D}
    .mline{font-size:13px;margin-bottom:8px;line-height:1.5}
    .mline-label{color:var(--color-text-secondary)}
    .demo-bar{background:#E1F5EE;border-bottom:0.5px solid #9FE1CB;padding:6px 1.25rem;display:flex;align-items:center;justify-content:space-between;font-size:12px;color:#085041;flex-shrink:0}
    .ob-footer{padding:1rem 1.25rem;border-top:0.5px solid var(--color-border-tertiary);display:flex;gap:10px;flex-shrink:0;background:var(--color-background-primary)}
    .flare-footer{padding:0.75rem 1.25rem;border-top:0.5px solid var(--color-border-tertiary);display:flex;gap:8px;flex-shrink:0;background:var(--color-background-primary)}
  </style>
</head>
<body>
<div class="app" id="app">

<div id="demo-bar" class="demo-bar" style="display:none">
  <span><i class="ti ti-presentation" style="font-size:14px;vertical-align:-2px" aria-hidden="true"></i> Demo mode — your data is preserved</span>
  <button class="btn-ghost" style="font-size:12px;color:#085041" onclick="exitDemo()">Exit demo</button>
</div>

<div class="top-bar" id="top-bar" style="display:none">
  <button class="back-btn" onclick="goBack()" aria-label="Go back"><i class="ti ti-arrow-left" aria-hidden="true"></i></button>
  <h1 id="top-title">MCAS Flare Guide</h1>
</div>

<!-- WELCOME -->
<div class="screen active" id="s-welcome">
  <div class="screen-scroll" style="display:flex;flex-direction:column;justify-content:center;min-height:100%">
    <div style="padding:1rem 0">
      <div style="width:48px;height:48px;background:#E1F5EE;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem">
        <i class="ti ti-heart" style="font-size:24px;color:#0F6E56" aria-hidden="true"></i>
      </div>
      <h2 style="font-size:22px;margin-bottom:0.5rem">MCAS Flare Guide</h2>
      <p style="margin-bottom:2rem">A personalized response guide for mast cell activation syndrome. Fill in what you can — bring it to your appointment to complete the rest with your provider.</p>
      <div class="section-label" style="margin-top:0">I am</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.5rem">
        <button class="btn btn-full ctx-btn" id="ctx-adult" onclick="setContext('adult')" style="padding:14px;flex-direction:column;gap:6px;border-radius:var(--border-radius-lg)">
          <i class="ti ti-user" style="font-size:20px" aria-hidden="true"></i>
          <span style="font-size:13px">An adult patient</span>
        </button>
        <button class="btn btn-full ctx-btn" id="ctx-care" onclick="setContext('caregiver')" style="padding:14px;flex-direction:column;gap:6px;border-radius:var(--border-radius-lg)">
          <i class="ti ti-users" style="font-size:20px" aria-hidden="true"></i>
          <span style="font-size:13px">A caregiver / parent</span>
        </button>
      </div>
      <button class="btn btn-primary btn-full btn-lg" onclick="startOnboarding()">Begin setup <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
      <button class="btn-ghost btn-full" onclick="goHome()" style="justify-content:center;margin-top:10px">Already set up — go to my guide <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
    </div>
  </div>
</div>

<!-- ONBOARDING 1 -->
<div class="screen" id="s-ob1">
  <div style="padding:1.25rem 1.25rem 0;flex-shrink:0">
    <div class="progress-bar"><div class="progress-fill" style="width:20%"></div></div>
    <div class="section-label" style="margin-top:0">Step 1 of 5 — Early warning signals</div>
    <h2 id="ob1-title">Your pre-flare pattern</h2>
    <p id="ob1-sub" style="margin-bottom:1rem">These are the signs your body gives before a full flare. Learning your personal pattern is one of the most powerful things you can do.</p>
  </div>
  <div class="screen-scroll">
    <div class="field"><label id="lb-earliest">My earliest warning signs are usually</label><textarea id="f-earliest" rows="3" placeholder="e.g. mild flushing, brain fog arriving, sense of unease, heart rate rising..."></textarea></div>
    <div class="field"><label id="lb-canary">My single most reliable first signal</label><input type="text" id="f-canary" placeholder="e.g. sudden fatigue that feels different from regular tiredness"></div>
    <div class="field"><label id="lb-context">I notice these signals most often when</label><input type="text" id="f-context" placeholder="e.g. afternoon, before period, after fragrance exposure, after stress"></div>
    <div class="field"><label id="lb-firstdo">When I notice these signals, I first</label><input type="text" id="f-firstdo" placeholder="e.g. take antihistamine, remove myself from the environment, lie down"></div>
  </div>
  <div class="ob-footer">
    <button class="btn" onclick="showScreen('s-welcome')"><i class="ti ti-arrow-left" aria-hidden="true"></i> Back</button>
    <button class="btn btn-primary" style="flex:1" onclick="saveOb1()">Next <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
  </div>
</div>

<!-- ONBOARDING 2 -->
<div class="screen" id="s-ob2">
  <div style="padding:1.25rem 1.25rem 0;flex-shrink:0">
    <div class="progress-bar"><div class="progress-fill" style="width:40%"></div></div>
    <div class="section-label" style="margin-top:0">Step 2 of 5 — Trigger map</div>
    <h2>Your triggers</h2>
    <p style="margin-bottom:1rem">List confirmed and suspected triggers. Goal: pattern recognition, not elimination.</p>
  </div>
  <div class="screen-scroll">
    <div class="field"><label>Food / ingested — confirmed</label><textarea id="f-food-c" rows="2" placeholder="e.g. aged cheese, leftover meals, red wine, spinach..."></textarea></div>
    <div class="field"><label>Food / ingested — suspected</label><textarea id="f-food-s" rows="2" placeholder="Foods you think may contribute but aren't certain about..."></textarea></div>
    <div class="field"><label>Chemical / environmental</label><textarea id="f-chem" rows="2" placeholder="e.g. fragrances, cleaning products, mold, new materials, exhaust..."></textarea></div>
    <div class="field"><label>Physical triggers</label><input type="text" id="f-phys" placeholder="e.g. heat, cold, exercise, pressure, sun exposure..."></div>
    <div class="field"><label>Biological / hormonal</label><input type="text" id="f-bio" placeholder="e.g. before period, infections, sleep deprivation..."></div>
    <div class="field"><label>Stress / autonomic</label><input type="text" id="f-stress" placeholder="e.g. anxiety, postural changes, emotional stress..."></div>
    <div class="field"><label>My highest-load combination</label><textarea id="f-stack" rows="2" placeholder="e.g. poor sleep + fragrance exposure + before period = almost always flare"></textarea></div>
  </div>
  <div class="ob-footer">
    <button class="btn" onclick="showScreen('s-ob1');loadOb1()"><i class="ti ti-arrow-left" aria-hidden="true"></i> Back</button>
    <button class="btn btn-primary" style="flex:1" onclick="saveOb2()">Next <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
  </div>
</div>

<!-- ONBOARDING 3 -->
<div class="screen" id="s-ob3">
  <div style="padding:1.25rem 1.25rem 0;flex-shrink:0">
    <div class="progress-bar"><div class="progress-fill" style="width:60%"></div></div>
    <div class="section-label" style="margin-top:0">Step 3 of 5 — Medications</div>
    <h2>Mild and moderate flare</h2>
    <p style="margin-bottom:1rem">Fill in what you know. Your provider will complete doses and confirm the plan.</p>
  </div>
  <div class="screen-scroll">
    <div class="section-label" style="margin-top:0">My Tier 1 warning signs</div>
    <div class="field"><textarea id="f-t1-signs" rows="2" placeholder="What does a mild flare feel like for you specifically?"></textarea></div>
    <div class="section-label">Tier 1 medications</div>
    <div class="lock-note"><i class="ti ti-lock" style="font-size:14px" aria-hidden="true"></i> Doses are completed with your provider at your appointment</div>
    <div class="provider-field"><label>Medication 1 / dose</label><input type="text" id="f-t1-m1" placeholder="e.g. cetirizine — dose to be confirmed with provider"></div>
    <div class="provider-field"><label>Medication 2 / dose</label><input type="text" id="f-t1-m2" placeholder="e.g. famotidine — dose to be confirmed with provider"></div>
    <div class="field"><label>Non-medication steps that help me at Tier 1</label><input type="text" id="f-t1-other" placeholder="e.g. cool environment, lie down, remove from trigger, hydrate"></div>
    <div class="section-label">My Tier 2 warning signs</div>
    <div class="field"><textarea id="f-t2-signs" rows="2" placeholder="What does a moderate flare feel like for you specifically?"></textarea></div>
    <div class="section-label">Tier 2 medications</div>
    <div class="provider-field"><label>Rescue antihistamine / dose / max doses per day</label><input type="text" id="f-t2-m1" placeholder="Complete with provider"></div>
    <div class="provider-field"><label>Oral steroid if prescribed / dose / when to use</label><input type="text" id="f-t2-m2" placeholder="Complete with provider"></div>
    <div class="field"><label>My personal escalation signal to Tier 3</label><input type="text" id="f-t2-esc" placeholder="The specific sign that tells me I need to escalate"></div>
  </div>
  <div class="ob-footer">
    <button class="btn" onclick="showScreen('s-ob2');loadOb2()"><i class="ti ti-arrow-left" aria-hidden="true"></i> Back</button>
    <button class="btn btn-primary" style="flex:1" onclick="saveOb3()">Next <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
  </div>
</div>

<!-- ONBOARDING 4 -->
<div class="screen" id="s-ob4">
  <div style="padding:1.25rem 1.25rem 0;flex-shrink:0">
    <div class="progress-bar"><div class="progress-fill" style="width:80%"></div></div>
    <div class="section-label" style="margin-top:0">Step 4 of 5 — Emergency information</div>
    <h2>Severe flare and emergency</h2>
    <p style="margin-bottom:1rem">Fill in everything you can. Your provider will confirm the clinical details.</p>
  </div>
  <div class="screen-scroll">
    <div class="section-label" style="margin-top:0">Epinephrine auto-injector</div>
    <div class="provider-field"><label>Device name and dose</label><input type="text" id="f-epi-device" placeholder="e.g. EpiPen 0.3mg — confirm with provider"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1rem">
      <div class="field"><label>Where I carry it</label><input type="text" id="f-epi-loc" placeholder="e.g. purse, backpack"></div>
      <div class="field"><label>Expiration date</label><input type="text" id="f-epi-exp" placeholder="MM/YYYY"></div>
    </div>
    <div class="field"><label>Second device location</label><input type="text" id="f-epi-loc2" placeholder="e.g. at home, at school nurse, at work"></div>
    <div class="section-label">Emergency contacts</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">
      <div class="field"><label>Contact 1 name</label><input type="text" id="f-ec1-name" placeholder="Name"></div>
      <div class="field"><label>Phone</label><input type="tel" id="f-ec1-phone" placeholder="Phone number"></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:1rem">
      <div class="field"><label>Contact 2 name</label><input type="text" id="f-ec2-name" placeholder="Name"></div>
      <div class="field"><label>Phone</label><input type="tel" id="f-ec2-phone" placeholder="Phone number"></div>
    </div>
    <div class="field"><label>Preferred hospital / ER</label><input type="text" id="f-er" placeholder="Hospital name and address"></div>
